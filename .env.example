# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Meta WhatsApp Cloud API ──────────────────────────────────────────────────
WHATSAPP_TOKEN=           # Permanent token from Meta System User
WHATSAPP_PHONE_ID=        # Phone Number ID from Meta App Dashboard
WHATSAPP_VERIFY_TOKEN=    # Any string you choose — used to verify webhook
MY_WHATSAPP_NUMBER=       # Your number in international format, no + (e.g. 94771234567)

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
TZ=Asia/Colombo   # Ensures dates use Sri Lanka time (UTC+5:30)
